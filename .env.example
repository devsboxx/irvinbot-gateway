# JWT — CRÍTICO: debe ser idéntico en auth, chat, docs y gateway
# Genera uno con: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-un-valor-secreto-igual-en-todos-los-servicios
ALGORITHM=HS256

# URLs de los microservicios
# ── Desarrollo local (cada servicio corre con uvicorn directamente) ────────────
AUTH_SERVICE_URL=http://localhost:8001
CHAT_SERVICE_URL=http://localhost:8002
DOCS_SERVICE_URL=http://localhost:8003

# ── Docker Compose (los servicios se resuelven por nombre de contenedor) ───────
# AUTH_SERVICE_URL=http://auth:8001
# CHAT_SERVICE_URL=http://chat:8002
# DOCS_SERVICE_URL=http://docs:8003
